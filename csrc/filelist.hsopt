rmapats_mop.o: rmapats.m
	@/apps/synopsys/vcs_2023/vcs/U-2023.03-SP2-8/linux/bin/cgmop1    -gen_obj rmapats.m rmapats_mop.o; rm -f rmapats.m; touch rmapats.m; touch rmapats_mop.o

rmapats.o: rmapats.c
	@$(CC_CG) $(CFLAGS_CG) -c -fPIC -x c -o rmapats.o rmapats.c
rmapats%.o: rmapats%.c
	@$(CC_CG) $(CFLAGS_CG) -c -fPIC -x c -o $@ $<
rmar.o: rmar.c
	@$(CC_CG) $(CFLAGS_RMAR) -c -fPIC -x c -o rmar.o rmar.c
rmar%.o: rmar%.c
	@$(CC_CG) $(CFLAGS_RMAR) -c -fPIC -x c -o $@ $<

include filelist.hsopt.objs
